{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "figure_id",
    "title",
    "scientific_conclusion",
    "audience",
    "panels",
    "uncertainty",
    "statistics",
    "legend",
    "export",
    "accessibility",
    "review_risks",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "figure_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "scientific_conclusion": {
      "type": "string",
      "minLength": 5
    },
    "audience": {
      "type": "string",
      "minLength": 1
    },
    "target_venue": {
      "type": "string"
    },
    "panels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "purpose",
          "kind",
          "chart_type",
          "data_sources",
          "transformations"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "purpose": {
            "type": "string",
            "minLength": 3
          },
          "kind": {
            "enum": [
              "quantitative",
              "qualitative",
              "schematic",
              "image",
              "table"
            ]
          },
          "chart_type": {
            "type": "string"
          },
          "data_sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "x_axis": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "unit": {
                "type": "string"
              },
              "scale": {
                "enum": [
                  "linear",
                  "log",
                  "symlog",
                  "categorical",
                  "date"
                ]
              },
              "start_at_zero": {
                "type": "boolean"
              }
            },
            "required": [
              "label",
              "unit",
              "scale",
              "start_at_zero"
            ],
            "additionalProperties": false
          },
          "y_axis": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "unit": {
                "type": "string"
              },
              "scale": {
                "enum": [
                  "linear",
                  "log",
                  "symlog",
                  "categorical"
                ]
              },
              "start_at_zero": {
                "type": "boolean"
              }
            },
            "required": [
              "label",
              "unit",
              "scale",
              "start_at_zero"
            ],
            "additionalProperties": false
          },
          "transformations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "uncertainty": {
      "type": "object",
      "required": [
        "type",
        "sample_size",
        "calculation"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "sample_size": {
          "type": "string"
        },
        "calculation": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "statistics": {
      "type": "object",
      "required": [
        "tests",
        "multiplicity"
      ],
      "properties": {
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "multiplicity": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "legend": {
      "type": "string"
    },
    "export": {
      "type": "object",
      "required": [
        "formats",
        "raster_dpi",
        "width_mm",
        "height_mm"
      ],
      "properties": {
        "formats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "png",
              "svg",
              "pdf",
              "tiff"
            ]
          }
        },
        "raster_dpi": {
          "type": "integer",
          "minimum": 72
        },
        "width_mm": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height_mm": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false
    },
    "accessibility": {
      "type": "object",
      "required": [
        "color_vision_checked",
        "alt_text"
      ],
      "properties": {
        "color_vision_checked": {
          "type": "boolean"
        },
        "alt_text": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "review_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "raw_data",
        "processed_data",
        "code"
      ],
      "properties": {
        "raw_data": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "processed_data": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "code": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
