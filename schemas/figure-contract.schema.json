{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://github.com/SUNHAOJUN22/TsaoSciResearcher/schemas/figure-contract.schema.json",
  "title":"TsaoSciResearcher figure contract","type":"object","additionalProperties":false,
  "required":["schema_version","figure_id","title","scientific_conclusion","audience","panels","uncertainty","statistics","legend","export","accessibility","review_risks","provenance"],
  "properties":{
    "schema_version":{"const":"1.0"},"figure_id":{"type":"string","pattern":"^FIG-[A-Za-z0-9._-]+$"},
    "title":{"type":"string"},"scientific_conclusion":{"type":"string","minLength":5},"audience":{"type":"string","minLength":1},"target_venue":{"type":"string"},
    "panels":{"type":"array","minItems":1,"items":{"type":"object","additionalProperties":false,"required":["id","purpose","kind","chart_type","data_sources","transformations"],"properties":{
      "id":{"type":"string","minLength":1},"purpose":{"type":"string","minLength":3},
      "kind":{"enum":["quantitative","qualitative","schematic","image","table"]},"chart_type":{"type":"string"},
      "data_sources":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string"}},
      "x_axis":{"$ref":"#/$defs/axis"},"y_axis":{"$ref":"#/$defs/axis"},
      "transformations":{"type":"array","uniqueItems":true,"items":{"type":"string"}}
    }}},
    "uncertainty":{"type":"object","additionalProperties":false,"required":["type","sample_size","calculation"],"properties":{"type":{"type":"string"},"sample_size":{"type":"string"},"calculation":{"type":"string"}}},
    "statistics":{"type":"object","additionalProperties":false,"required":["tests","multiplicity"],"properties":{"tests":{"type":"array","uniqueItems":true,"items":{"type":"string"}},"multiplicity":{"type":"string"}}},
    "legend":{"type":"string"},
    "export":{"type":"object","additionalProperties":false,"required":["formats","raster_dpi","width_mm","height_mm"],"properties":{"formats":{"type":"array","minItems":1,"uniqueItems":true,"items":{"enum":["png","svg","pdf","tiff"]}},"raster_dpi":{"type":"integer","minimum":72,"maximum":2400},"width_mm":{"type":"number","exclusiveMinimum":0},"height_mm":{"type":"number","exclusiveMinimum":0}}},
    "accessibility":{"type":"object","additionalProperties":false,"required":["color_vision_checked","alt_text"],"properties":{"color_vision_checked":{"type":"boolean"},"alt_text":{"type":"string","minLength":1}}},
    "review_risks":{"type":"array","uniqueItems":true,"items":{"type":"string"}},
    "provenance":{"type":"object","additionalProperties":false,"required":["raw_data","processed_data","code"],"properties":{"raw_data":{"type":"array","uniqueItems":true,"items":{"type":"string"}},"processed_data":{"type":"array","uniqueItems":true,"items":{"type":"string"}},"code":{"type":"array","uniqueItems":true,"items":{"type":"string"}}}}
  },
  "$defs":{"axis":{"type":["object","null"],"additionalProperties":false,"required":["label","unit","scale","start_at_zero"],"properties":{"label":{"type":"string"},"unit":{"type":"string"},"scale":{"enum":["linear","log","symlog","categorical","date"]},"start_at_zero":{"type":"boolean"}}}}
}
