{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SUNHAOJUN22/TsaoSciResearcher/schemas/claim.schema.json",
  "title": "TsaoSciResearcher claim",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","claim_id","statement","claim_type","evidence_ids","assumptions","status","limitations"],
  "properties": {
    "schema_version": {"const":"1.0"},
    "claim_id": {"type":"string","pattern":"^CL-[A-Za-z0-9][A-Za-z0-9._-]*$","maxLength":128},
    "statement": {"type":"string","minLength":1,"maxLength":20000},
    "claim_type": {"enum":["observation","calculation","sourced_fact","inference","hypothesis","recommendation","open_question"]},
    "evidence_ids": {"type":"array","uniqueItems":true,"items":{"type":"string","pattern":"^EV-[A-Za-z0-9][A-Za-z0-9._-]*$","maxLength":128}},
    "assumptions": {"type":"array","uniqueItems":true,"items":{"type":"string","minLength":1,"maxLength":4000}},
    "status": {"enum":["proposed","checked","validated","accepted","rejected","superseded"]},
    "limitations": {"type":"array","uniqueItems":true,"items":{"type":"string","minLength":1,"maxLength":4000}},
    "confidence": {"type":"number","minimum":0,"maximum":1}
  }
}
