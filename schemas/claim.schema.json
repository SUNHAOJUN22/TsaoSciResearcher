{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "claim_id",
    "statement",
    "claim_type",
    "evidence_ids",
    "assumptions",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "claim_id": {
      "type": "string",
      "pattern": "^CL-[A-Za-z0-9._-]+$"
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "claim_type": {
      "enum": [
        "observation",
        "calculation",
        "sourced_fact",
        "inference",
        "hypothesis",
        "recommendation",
        "open_question"
      ]
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^EV-"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": [
        "proposed",
        "checked",
        "validated",
        "accepted",
        "rejected",
        "superseded"
      ]
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
