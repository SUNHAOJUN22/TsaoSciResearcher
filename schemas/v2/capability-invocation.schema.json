{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sunhaojun22.github.io/TsaoSciResearcher/schemas/v2/capability-invocation.schema.json",
  "title": "Capability Invocation",
  "type": "object",
  "required": [
    "schema_version",
    "invocation_id",
    "capability_slug",
    "inputs",
    "requested_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "invocation_id": {
      "type": "string",
      "minLength": 3
    },
    "capability_slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "inputs": {
      "type": "object"
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 86400
    },
    "dry_run": {
      "type": "boolean"
    },
    "human_approval_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
