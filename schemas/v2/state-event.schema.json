{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sunhaojun22.github.io/TsaoSciResearcher/schemas/v2/state-event.schema.json",
  "title": "Hash-linked Project Event",
  "type": "object",
  "required": [
    "event_id",
    "project_id",
    "action",
    "timestamp",
    "previous_state",
    "next_state",
    "reason",
    "related_ids",
    "previous_event_hash",
    "event_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 3
    },
    "project_id": {
      "type": "string",
      "minLength": 3
    },
    "action": {
      "type": "string",
      "minLength": 3
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "previous_state": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        }
      ]
    },
    "next_state": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "related_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "previous_event_hash": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      ]
    },
    "event_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
