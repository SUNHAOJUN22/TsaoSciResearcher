{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "handoff_id",
    "scientific_question",
    "target_property",
    "scale",
    "candidate_methods",
    "inputs",
    "boundary_conditions",
    "initial_conditions",
    "parameter_sources",
    "convergence_checks",
    "uncertainty_analysis",
    "expected_outputs",
    "acceptance_criteria",
    "evidence_level",
    "human_approval_points"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "handoff_id": {
      "type": "string"
    },
    "scientific_question": {
      "type": "string",
      "minLength": 3
    },
    "target_property": {
      "type": "string",
      "minLength": 1
    },
    "scale": {
      "enum": [
        "electronic",
        "atomistic",
        "mesoscale",
        "continuum",
        "device",
        "process",
        "multiscale"
      ]
    },
    "candidate_methods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "boundary_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "initial_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "parameter_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "convergence_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "uncertainty_analysis": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "evidence_level": {
      "enum": [
        "planned",
        "prepared",
        "executed",
        "checked",
        "validated",
        "accepted"
      ]
    },
    "human_approval_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
