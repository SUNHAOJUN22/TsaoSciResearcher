{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "protocol_id",
    "objective",
    "hypotheses",
    "experimental_unit",
    "factors",
    "responses",
    "controls",
    "quality_controls",
    "analysis_plan"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "protocol_id": {
      "type": "string"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "hypotheses": {
      "type": "array"
    },
    "experimental_unit": {
      "type": "string",
      "minLength": 1
    },
    "factors": {
      "type": "array"
    },
    "responses": {
      "type": "array"
    },
    "controls": {
      "type": "array"
    },
    "randomization": {
      "type": "string"
    },
    "blinding": {
      "type": "string"
    },
    "replication": {
      "type": "string"
    },
    "sample_size_basis": {
      "type": "string"
    },
    "measurement_plan": {
      "type": "array"
    },
    "quality_controls": {
      "type": "array"
    },
    "exclusion_rules": {
      "type": "array"
    },
    "stopping_rules": {
      "type": "array"
    },
    "safety_review": {
      "type": "string"
    },
    "analysis_plan": {
      "type": "string",
      "minLength": 1
    }
  }
}
