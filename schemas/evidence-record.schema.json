{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "evidence_type",
    "title",
    "source",
    "supports_claims",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "evidence_id": {
      "type": "string",
      "pattern": "^EV-[A-Za-z0-9._-]+$"
    },
    "evidence_type": {
      "enum": [
        "observation",
        "calculation",
        "sourced_fact",
        "dataset",
        "instrument_output",
        "expert_review"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "kind",
        "locator"
      ],
      "properties": {
        "kind": {
          "enum": [
            "paper",
            "dataset",
            "web",
            "file",
            "experiment",
            "computation",
            "instrument",
            "expert"
          ]
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "accessed_at": {
          "type": "string"
        },
        "checksum": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "supports_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
