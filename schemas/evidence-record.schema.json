{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SUNHAOJUN22/TsaoSciResearcher/schemas/evidence-record.schema.json",
  "title": "TsaoSciResearcher evidence record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","evidence_id","evidence_type","title","source","supports_claims","limitations"],
  "properties": {
    "schema_version": {"const":"1.0"},
    "evidence_id": {"type":"string","pattern":"^EV-[A-Za-z0-9][A-Za-z0-9._-]*$","maxLength":128},
    "evidence_type": {"enum":["observation","calculation","sourced_fact","dataset","instrument_output","expert_review"]},
    "title": {"type":"string","minLength":1,"maxLength":2000},
    "source": {
      "type":"object","additionalProperties":false,"required":["kind","locator"],
      "properties": {
        "kind": {"enum":["paper","dataset","web","file","experiment","computation","instrument","expert"]},
        "locator": {"type":"string","minLength":1,"maxLength":8192},
        "accessed_at": {"type":"string","format":"date-time"},
        "checksum": {"type":"string","pattern":"^(?:sha256:)?[0-9A-Fa-f]{64}$"}
      }
    },
    "supports_claims": {"type":"array","uniqueItems":true,"items":{"type":"string","pattern":"^CL-[A-Za-z0-9][A-Za-z0-9._-]*$","maxLength":128}},
    "refutes_claims": {"type":"array","uniqueItems":true,"items":{"type":"string","pattern":"^CL-[A-Za-z0-9][A-Za-z0-9._-]*$","maxLength":128}},
    "limitations": {"type":"array","uniqueItems":true,"items":{"type":"string","minLength":1,"maxLength":4000}},
    "notes": {"type":"string","maxLength":20000}
  }
}
